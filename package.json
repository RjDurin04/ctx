{
  "name": "@ctx-compiler/ctx",
  "version": "0.2.0",
  "description": "Codebase Context Compiler — compile any repo into an AI-readable map",
  "type": "module",
  "license": "MIT",
  "author": "Rj Durin",
  "repository": {
    "type": "git",
    "url": "https://github.com/RjDurin04/ctx.git"
  },
  "homepage": "https://github.com/RjDurin04/ctx",
  "keywords": [
    "codebase",
    "context",
    "ast",
    "mcp",
    "tree-sitter",
    "cli",
    "ai",
    "llm",
    "code-analysis",
    "model-context-protocol"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ctx": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"import{cpSync,mkdirSync}from'fs';mkdirSync('dist/storage',{recursive:true});cpSync('src/storage/schema.sql','dist/storage/schema.sql')\"",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "get-tsconfig": "^4.13.6",
    "ignore": "^5.3.2",
    "minisearch": "^7.2.0",
    "web-tree-sitter": "^0.24.7",
    "tree-sitter-wasms": "^0.1.12",
    "chalk": "^5.6.2",
    "ora": "^8.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}